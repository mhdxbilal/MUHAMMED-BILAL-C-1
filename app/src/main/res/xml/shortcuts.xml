<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="shortcut_player"
        android:enabled="true"
        android:icon="@drawable/ic_play"
        android:shortcutShortLabel="@string/action_play"
        android:shortcutLongLabel="@string/action_play">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.continental.player"
            android:targetClass="com.continental.player.PlayerActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>
    <shortcut
        android:shortcutId="shortcut_settings"
        android:enabled="true"
        android:icon="@drawable/ic_subtitles"
        android:shortcutShortLabel="@string/action_settings"
        android:shortcutLongLabel="@string/action_settings">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.continental.player"
            android:targetClass="com.continental.player.SettingsActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>
</shortcuts>
