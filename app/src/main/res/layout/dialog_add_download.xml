<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="URL / Link">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Quality"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rgQuality"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <RadioButton
            android:id="@+id/rbQ2160"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2160p (4K)" />

        <RadioButton
            android:id="@+id/rbQ1080"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1080p" />

        <RadioButton
            android:id="@+id/rbQ720"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="720p" />

        <RadioButton
            android:id="@+id/rbQ480"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="480p" />

        <RadioButton
            android:id="@+id/rbBest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Best Available" />

        <RadioButton
            android:id="@+id/rbAudioOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio Only (MP3)" />
    </RadioGroup>

</LinearLayout>
